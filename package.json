{
  "name": "osanpo-bingo",
  "version": "0.1.0",
  "private": true,
  "description": "街で見つけものをする幼児向けおさんぽビンゴ（PWA・バックエンドレス）",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsgo --noEmit",
    "build": "tsgo --noEmit && vite build",
    "preview": "vite preview --host",
    "lint": "oxlint src",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260527.2",
    "@vitejs/plugin-react": "^4.3.4",
    "oxfmt": "^0.52.0",
    "oxlint": "^0.13.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
